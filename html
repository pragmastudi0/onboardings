let currentQuestion = 0;
const answers = {};

function getSectionName(section) {
  switch(section) {
    case 'A': return 'A · Bloque crítico';
    case 'B': return 'B · Modelo de datos';
    case 'C': return 'C · Operación';
    case 'D': return 'D · Reportes y branding';
    default: return section;
  }
}

// Initialize
document.getElementById('total-q').textContent = questions.length;

function buildNavigatorGrid() {
  const grid = document.getElementById('navigator-grid');
  grid.innerHTML = '';
  
  questions.forEach((q, index) => {
    const item = document.createElement('button');
    item.className = 'navigator-item';
    item.textContent = index + 1;
    item.id = 'nav-' + index;
    item.type = 'button';
    
    if (q.answered) {
      item.classList.add('answered');
    }
    
    if (index === currentQuestion) {
      item.classList.add('current');
    }
    
    item.onclick = (e) => {
      e.preventDefault();
      showQuestion(index);
    };
    
    item.title = `P${index + 1}: ${q.title.substring(0, 50)}`;
    
    grid.appendChild(item);
  });
}

function toggleNavigator() {
  const grid = document.getElementById('navigator-grid');
  const btn = document.getElementById('navigator-toggle');
  
  grid.classList.toggle('collapsed');
  
  if (grid.classList.contains('collapsed')) {
    btn.textContent = '+';
  } else {
    btn.textContent = '−';
  }
}

function showQuestion(index) {
  currentQuestion = index;
  const q = questions[index];
  
  document.getElementById('q-title').textContent = q.title;
  document.getElementById('current-q').textContent = index + 1;
  document.getElementById('section-badge').textContent = getSectionName(q.section);
  
  const progressPercent = ((index + 1) / questions.length) * 100;
  document.getElementById('progress-bar').style.width = progressPercent + '%';
  
  const remainingQuestions = questions.length - index - 1;
  const estimatedMinutes = Math.ceil(remainingQuestions * 0.5);
  document.getElementById('estimated-time').textContent = (estimatedMinutes > 0 ? estimatedMinutes + ' min' : 'Listo!');
  
  const optionsDiv = document.getElementById('q-options');
  const hintDiv = document.getElementById('options-hint');
  optionsDiv.innerHTML = '';
  
  document.getElementById('q-text-input').classList.remove('active');
  
  if (q.type === 'multiple') {
    hintDiv.textContent = '👇 Podés seleccionar una o más opciones';
    hintDiv.style.display = 'block';
    
    q.options.forEach((opt, optIndex) => {
      const label = document.createElement('label');
      label.className = 'option-label';
      
      const input = document.createElement('input');
      input.type = 'checkbox';
      input.name = 'option-' + index + '-' + optIndex;
      input.value = opt;
      
      if (!answers[q.id]) {
        answers[q.id] = [];
      }
      input.checked = answers[q.id].includes(opt);
      
      input.onchange = (e) => {
        if (e.target.checked) {
          if (!answers[q.id].includes(opt)) {
            answers[q.id].push(opt);
          }
        } else {
          answers[q.id] = answers[q.id].filter(a => a !== opt);
        }
        questions[index].answered = answers[q.id].length > 0;
        buildNavigatorGrid();
      };
      
      const span = document.createElement('span');
      span.className = 'option-text';
      span.textContent = opt;
      
      label.appendChild(input);
      label.appendChild(span);
      optionsDiv.appendChild(label);
    });
  } else {
    hintDiv.style.display = 'none';
    document.getElementById('q-text-input').classList.add('active');
    const textarea = document.getElementById('text-answer');
    textarea.value = answers[q.id] || '';
    textarea.placeholder = q.placeholder || 'Escribí aquí tu respuesta...';
    textarea.oninput = (e) => {
      answers[q.id] = e.target.value;
      questions[index].answered = e.target.value.trim().length > 0;
      buildNavigatorGrid();
    };
  }
  
  document.getElementById('btn-prev').classList.toggle('visible', index > 0);
  document.getElementById('btn-next').style.display = index < questions.length - 1 ? 'block' : 'none';
  document.getElementById('btn-finish').style.display = index === questions.length - 1 ? 'block' : 'none';
  
  buildNavigatorGrid();
}

function nextQuestion() {
  if (currentQuestion < questions.length - 1) {
    showQuestion(currentQuestion + 1);
  }
}

function previousQuestion() {
  if (currentQuestion > 0) {
    showQuestion(currentQuestion - 1);
  }
}

function finishQuiz() {
  document.getElementById('quiz-main').classList.remove('active');
  document.getElementById('quiz-review').classList.add('active');
  
  const reviewSectionsDiv = document.getElementById('review-sections');
  reviewSectionsDiv.innerHTML = '';
  
  const groupedBySection = {};
  questions.forEach(q => {
    const answer = answers[q.id];
    if (answer && ((Array.isArray(answer) && answer.length > 0) || (!Array.isArray(answer) && answer.trim()))) {
      if (!groupedBySection[q.section]) {
        groupedBySection[q.section] = [];
      }
      groupedBySection[q.section].push(q);
    }
  });
  
  Object.keys(groupedBySection).sort().forEach(section => {
    const sectionDiv = document.createElement('div');
    sectionDiv.className = 'review-section';
    
    const sectionTitle = document.createElement('div');
    sectionTitle.className = 'review-section-title';
    sectionTitle.textContent = getSectionName(section);
    sectionDiv.appendChild(sectionTitle);
    
    const gridDiv = document.createElement('div');
    gridDiv.className = 'review-grid';
    
    groupedBySection[section].forEach(q => {
      const answer = answers[q.id];
      const card = document.createElement('div');
      card.className = 'review-card';
      
      const label = document.createElement('div');
      label.className = 'review-card-label';
      label.textContent = q.type === 'multiple' ? 'Opción(es) seleccionada(s)' : 'Respuesta libre';
      
      const question = document.createElement('div');
      question.className = 'review-card-question';
      question.textContent = q.title;
      
      const answerDiv = document.createElement('div');
      answerDiv.className = 'review-card-answer';
      
      if (Array.isArray(answer)) {
        answerDiv.innerHTML = answer.map(a => `<div style="margin-bottom: 8px;">✓ ${a}</div>`).join('');
      } else {
        answerDiv.textContent = answer;
      }
      
      card.appendChild(label);
      card.appendChild(question);
      card.appendChild(answerDiv);
      gridDiv.appendChild(card);
    });
    
    sectionDiv.appendChild(gridDiv);
    reviewSectionsDiv.appendChild(sectionDiv);
  });
}

function copyAnswers() {
  let text = 'RESPUESTAS DEL CUESTIONARIO ONBOARDING\n';
  text += '='.repeat(60) + '\n\n';
  text += 'Pragma Studio - Cuestionario de descubrimiento\n';
  text += 'Fecha: ' + new Date().toLocaleDateString('es-AR') + '\n';
  text += 'Preguntas respondidas: ' + Object.keys(answers).length + ' de ' + questions.length + '\n\n';
  text += '='.repeat(60) + '\n\n';
  
  let currentSection = '';
  questions.forEach(q => {
    const answer = answers[q.id];
    if (answer && ((Array.isArray(answer) && answer.length > 0) || (!Array.isArray(answer) && answer.trim()))) {
      if (currentSection !== q.section) {
        currentSection = q.section;
        text += '\n' + getSectionName(q.section) + '\n';
        text += '-'.repeat(50) + '\n\n';
      }
      text += '• ' + q.title + '\n';
      if (Array.isArray(answer)) {
        answer.forEach(a => {
          text += '  ✓ ' + a + '\n';
        });
      } else {
        text += '  ' + answer + '\n';
      }
      text += '\n';
    }
  });
  
  navigator.clipboard.writeText(text).then(() => {
    const btn = event.target;
    const originalText = btn.innerHTML;
    btn.innerHTML = '<span>✓</span> ¡Copiado!';
    btn.style.background = '#22c55e';
    setTimeout(() => {
      btn.innerHTML = originalText;
      btn.style.background = '';
    }, 2000);
  });
}

